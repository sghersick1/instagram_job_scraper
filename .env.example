INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Option A: path to a service account JSON file
GOOGLE_CREDENTIALS_JSON_PATH=/path/to/service_account.json
# Option B: raw JSON string (useful in Docker/CI — takes precedence over the path if set)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Comma-separated list of Instagram accounts to monitor
TARGET_ACCOUNTS=zero2sudo

# How often to run (minutes). Only used in --schedule mode.
SCRAPE_INTERVAL_MINUTES=30
